NODE_ENV=production
PORT=5000

# Comma-separated list of allowed frontend origins.
# Example: https://mechanic-finder-frontend.onrender.com,https://your-custom-domain.com
CORS_ORIGIN=https://mechanic-finder-frontend.onrender.com
FRONTEND_URL=https://mechanic-finder-frontend.onrender.com

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
DB_NAME=findmech

JWT_SECRET=replace_with_a_long_random_secret

# Email / SMTP settings (optional but required for forgot-password OTP emails)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Cloudinary (required if profile/image upload is used)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
